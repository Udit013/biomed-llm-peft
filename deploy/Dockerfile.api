# FastAPI backend image for FREE-TIER Render. Torch-free and small: query
# embeddings + the 7B LLM are both served via HF Inference, so no local model.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1 \
    BIOMED_EMBEDDING_PROVIDER=hf_inference \
    BIOMED_INFERENCE_PROVIDER=hf_inference \
    BIOMED_VECTOR_BACKEND=pgvector \
    BIOMED_USE_RERANKER=false
WORKDIR /app

# Lean deps only (no torch / sentence-transformers). Copy first for layer caching.
COPY requirements-api.txt .
RUN pip install --upgrade pip && pip install -r requirements-api.txt

COPY src/ ./src/
COPY configs/ ./configs/
# Precomputed Benchmark Explorer data is optional at build time; the API serves
# /benchmark only if results/benchmark_explorer.json is mounted/committed. Do NOT
# COPY it here (it may not exist yet and would fail the build).

EXPOSE 8000
# Render provides $PORT; default 8000 locally.
CMD ["sh", "-c", "uvicorn src.assistant.api.app:app --host 0.0.0.0 --port ${PORT:-8000}"]
