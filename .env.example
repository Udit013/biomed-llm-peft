# Copy to .env and fill in. .env is gitignored and must never be committed.
# All keys are OPTIONAL — the pipeline runs without them (W&B degrades to
# local logging; Hub push is skipped if no token).

# Weights & Biases (optional). If unset, training logs locally only.
WANDB_API_KEY=
WANDB_PROJECT=biomed-llm-peft
WANDB_ENTITY=

# Hugging Face Hub (optional). Needed only to push the LoRA adapter/model card.
HF_TOKEN=
HF_HUB_REPO_ID=your-username/qwen2.5-7b-medmcqa-qlora

# Disable W&B explicitly regardless of key presence.
WANDB_MODE=online
